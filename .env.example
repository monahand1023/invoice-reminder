# Copy to .env and fill in. .env is git-ignored. NEVER commit real secrets.

# ---------------------------------------------------------------------------
# SAFETY SEATBELT #2
# A real send is impossible unless this is set to exactly "1".
# Even `run --send` + `approve` will refuse to touch SMTP without it.
# Leave it unset (or 0) for every dry-run and every demo.
# ---------------------------------------------------------------------------
REMINDERS_ALLOW_SEND=0

# SMTP credentials — only consulted in --send mode after approval.
# For Gmail, generate an *app password* (account must have 2FA) and use that
# here. Do NOT use your normal Google account password.
SMTP_USERNAME=billing@acmemagazine.example
SMTP_PASSWORD=your-gmail-app-password-here

# Only needed if you enable the OPTIONAL LLM tone-rewrite (tone_rewrite.enabled
# in config.yaml). Left unset, the tool is fully deterministic and never calls out.
# ANTHROPIC_API_KEY=sk-ant-...
